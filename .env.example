# Environment
ENV=development
DEBUG=true

# Video
VIDEO__WIDTH=1080
VIDEO__HEIGHT=1920
VIDEO__DPI=100
VIDEO__FPS=30
VIDEO__TOTAL_DURATION=30
VIDEO__CODEC=libx264
VIDEO__BITRATE=8000
VIDEO__PRESET=medium
VIDEO__CRF=20
VIDEO__PIX_FMT=yuv420p
VIDEO__OUTPUT_DIR=runtime/outputs

# API (optional)
# API__OPENAI_API_KEY=your_openai_api_key_here
API__OPENAI_MODEL=gpt-3.5-turbo
API__OPENAI_TIMEOUT=30

# API__PEXELS_API_KEY=your_pexels_api_key_here
API__PEXELS_TIMEOUT=15
API__PEXELS_CACHE_DIR=runtime/pexels_cache
API__MAX_RETRIES=3
API__RETRY_BACKOFF_FACTOR=2.0

# Log
LOG__LOG_LEVEL=INFO
LOG__LOG_DIR=runtime/logs
LOG__LOG_TO_FILE=true
LOG__LOG_TO_CONSOLE=true
LOG__MAX_LOG_SIZE=10485760
LOG__BACKUP_COUNT=5

# Runtime paths
CACHE_DIR=runtime/cache
TEMP_DIR=runtime/temp

# Loan defaults
DEFAULT_LOAN_AMOUNT=1000000
DEFAULT_ANNUAL_RATE=0.045
DEFAULT_LOAN_YEARS=30
