# 复制本文件为项目根目录下的 .env 后按需修改（不要提交真实密钥到 Git）
# 更全的示例见 scripts/.env.example

# ── Studio 作业库（可选；不设则使用默认 SQLite：runtime/studio.db）────
# STUDIO__DATABASE_URL=sqlite:////absolute/path/to/studio.db
# STUDIO__DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/studio

# ── 控制台监听（可选；也可用命令行 python main.py dashboard --host ...）──
# DASHBOARD_HOST=0.0.0.0
# DASHBOARD_PORT=8090

# ── 外部 API（可选；不配则仅影响需要大模型/图库的功能）────────────────
# 命名规则见 shared/config/settings.py（嵌套前缀 API__）
# API__OPENAI_COMPATIBLE_API_KEY=
# API__OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
# API__OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
# API__PEXELS_API_KEY=
